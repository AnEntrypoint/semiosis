def test_batch_contains_shape() -> None:
    engine = HyperbolicConeEngine(ConeSettings())
    tree = _dummy_tree(n=3)
    nodes = engine.fit(tree)
    mat = engine.batch_contains(nodes, nodes)
    assert mat.shape == (len(nodes), len(nodes))