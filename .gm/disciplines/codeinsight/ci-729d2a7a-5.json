def _hilbert_d2xy_free(order: int, x: int, y: int) -> int:
    """Convert 2D grid coords to 1D Hilbert distance; standard bit-rotation algorithm."""
    d = 0
    s = 1 << (order - 1)
    while s > 0:
        rx = 1 if (x & s) > 0 else 0
        ry = 1 if (y & s) > 0 else 0
        d += s * s * ((3 * rx) ^ ry)
        if ry == 0:
            if rx == 1:
                x = s - 1 - x
                y = s - 1 - y
            x, y = y, x
        s >>= 1
    return d