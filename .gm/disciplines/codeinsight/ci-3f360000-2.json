def _compute_entropy(values: np.ndarray) -> float:
    """Shannon entropy of normalized value distribution."""
    if len(values) == 0:
        return 0.0
    v = np.abs(values)
    if np.sum(v) == 0:
        return 0.0
    p = v / np.sum(v)
    return float(-np.sum(p * (np.log(p + 1e-10))))