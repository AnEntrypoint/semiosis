def _five_node_chain() -> ClusterTree:
    return ClusterTree(
        edges=(
            (NodeId("l0"), NodeId("l1")),
            (NodeId("l1"), NodeId("l2")),
            (NodeId("l2"), NodeId("l3")),
            (NodeId("l3"), NodeId("l4")),
        ),
        assignments={PhraseId(f"phrase_{i}"): NodeId(f"l{i}") for i in range(5)},
        prefix=Prefix(64),
    )