def test_empty_tree_returns_no_nodes() -> None:
    tree = ClusterTree(edges=(), assignments={}, prefix=Prefix(64))
    cfg = ConeFitConfig(epochs=5, dim=4, seed=0)
    nodes = list(HyperbolicConeEngine(cfg).fit(tree))
    assert nodes == []