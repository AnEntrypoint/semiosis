def test_max_pinned_eviction() -> None:
    s = Settings()
    s.memory.max_pinned = 2
    mem = SemioticMemory(None, [], s)
    mem.remember("a", "f1")
    mem.remember("b", "f2")
    mem.remember("c", "f3")
    ids = {f.id for f in mem.facts()}
    assert len(ids) == 2
    assert "f1" not in ids