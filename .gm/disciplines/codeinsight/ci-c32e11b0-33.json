def test_in_memory_store_upsert() -> None:
    import numpy as np
    cfg = ConeFitConfig(epochs=5, dim=4, seed=0)
    engine = HyperbolicConeEngine(cfg)
    nodes = list(engine.fit(_two_node_tree()))
    store = InMemoryStore()
    for n in nodes:
        store.upsert(n)
    assert len(store.all_nodes()) == len(nodes)