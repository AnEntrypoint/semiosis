2826533,0.03788048028945923,0.017871858552098274,-0.004049884155392647,0.08695531636476517,0.08332067728042603,0.04360707104206085,0.03977535665035248,-0.022227657958865166,0.00908577349036932,0.01414804719388485,0.0044565084390342236,-0.005947015713900328,-0.02904040552675724,0.017638303339481354,0.08832456171512604,0.05873244255781174,-0.005632901098579168,-0.03791499137878418,-0.035912998020648956,0.021822625771164894,0.053681567311286926,-0.06207456812262535,0.019339051097631454,-0.06484060734510422,-0.029872704297304153,0.012601811438798904,-0.026071876287460327,-0.021426767110824585,-0.018429219722747803,-0.004358693491667509,0.011133339256048203,0.022155411541461945,0.04954827204346657,-0.06318619847297668,-0.09861818701028824,0.012347005307674408,-0.0016275238012894988,-0.039024412631988525,0.049655281007289886,0.02701483853161335,-0.02214195765554905],"key":"ci-152f2ea0-1","kind":"class_definition","le":65,"ls":17,"name":"InMemoryStore","text":"core/store.py:17:65 InMemoryStore\nclass InMemoryStore:\n    \"\"\"Satisfies the Store protocol with a plain dict; no HNSW, no lakeFS.\"\"\"\n\n    def __init__(self) -> None:\n        self._nodes: dict[NodeId, ConeNode] = {}\n\n    def write(self, nodes: Sequence[ConeNode], at: CommitId) -> CommitId:\n        \"\"\"Store nodes under the given commit handle and return it.\"\"\"\n        for n in nodes:\n            self._nodes[n.id] = n\n        return at\n\n    def knn(self, q: EuclideanVec, k: int, prefix: Prefix) -> Sequence[NodeId]:\n        \"\"\"Return up to k node IDs ranked by cosine similarity to q on spatial apex dims.\"\"\"\n        if not self._nodes:\n            return []\n        q_flat = np.asarray(q, dtype=np.float32).ravel()[:prefix]\n        scores: list[tuple[float, NodeId]] = []\n        for nid, node in self._nodes.items():\n            # skip time component [0]; take spatial dims [1:prefix+1]\n            spatial = node.apex[1:prefix + 1].astype(np.float32)\n            length = min(len(spatial), len(q_flat))\n            s = float(np.dot(spatial[:length], q_flat[:length]))\n            scores.append((s, nid))\n        scores.sort(reverse=True)\n        return [nid for _, nid in scores[:k]]\n\n    def upsert(self, node: ConeNode) -> None:\n        self._nodes[node.id] = node\n\n    def get(self, nid: NodeId) -> ConeNode:\n        return self._nodes[nid]\n\n    def all_nodes(self) -> list[ConeNode]:\n        return list(self._nodes.values())\n\n    def save(self, path: \"str | os.PathLike[str]\") -> None:\n        \"\"\"Write all nodes to a JSON file; lossless via cone_node_to_dict.\"\"\"\n        data = [cone_node_to_dict(n) for n in self._nodes.values()]\n        with open(path, \"w\", encoding=\"utf-8\") as f:\n            json.dump(data, f)\n\n    def load(self, path: \"str | os.PathLike[str]\") -> None:\n        \"\"\"Read nodes from a JSON file written by save(); merges into existing store.\"\"\"\n        with open(path, encoding=\"utf-8\") as f:\n            data = json.load(f)\n        for d in data:\n            node = cone_node_from_dict(d)\n            self._nodes[node.id] = node"}],"hash":355413664,"path":"core/store.py"}