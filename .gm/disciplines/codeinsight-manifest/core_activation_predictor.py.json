nsformer activations (NLA-inspired).\"\"\"\n\n    def __init__(self, input_dim: int, output_dim: int):\n        self._input_dim = input_dim\n        self._output_dim = output_dim\n        rng = np.random.default_rng(42)\n        raw = rng.standard_normal((input_dim, output_dim))\n        # Initialize as random orthogonal-ish projection\n        self._W = raw / (np.linalg.norm(raw, axis=0, keepdims=True) + _EPS)\n\n    def predict_embedding(self, activations: list) -> np.ndarray:\n        \"\"\"Project activations via W, normalize to unit vector.\"\"\"\n        v = np.array(activations, dtype=float)\n        out = v @ self._W\n        norm = np.linalg.norm(out)\n        return out / (norm + _EPS)\n\n    def fit(self, activation_samples: list, embedding_samples: list) -> None:\n        \"\"\"Least-squares fit W to minimize ||A @ W - E||^2.\"\"\"\n        A = np.array(activation_samples, dtype=float)\n        E = np.array(embedding_samples, dtype=float)\n        result, _, _, _ = np.linalg.lstsq(A, E, rcond=None)\n        self._W = result\n\n    def calibration_error(self, activation_samples: list, embedding_samples: list) -> float:\n        \"\"\"Mean cosine distance between predicted and actual embeddings.\"\"\"\n        errs = []\n        for act, emb in zip(activation_samples, embedding_samples):\n            pred = self.predict_embedding(act)\n            e = np.array(emb, dtype=float)\n            e_norm = e / (np.linalg.norm(e) + _EPS)\n            errs.append(1.0 - float(np.dot(pred, e_norm)))\n        return float(np.mean(errs)) if errs else 0.0"},{"body":"def stub_activations(text: str, dim: int = 64) -> list:\n    \"\"\"Deterministic stub: hash text to seed, return random unit vector of dim floats.\"\"\"\n    seed = int(hashlib.md5(text.encode()).hexdigest(), 16) % (2**31)\n    rng = np.random.default_rng(seed)\n    v = rng.standard_normal(dim)\n    v = v / (np.linalg.norm(v) + _EPS)\n    return v.tolist()","emb":[-0.03305565193295479,-0.05702986568212509,-0