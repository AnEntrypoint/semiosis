ideanVec:\r\n        dim = max(self._octaves)\r\n        out = np.empty((len(texts), dim), dtype=np.float32)\r\n        for i, text in enumerate(texts):\r\n            # deterministic per text: hash combines base seed with text content\r\n            rng = np.random.default_rng(self._base_seed ^ (hash(text) & 0xFFFF_FFFF_FFFF_FFFF))\r\n            v = rng.standard_normal(dim).astype(np.float32)\r\n            norm = float(np.linalg.norm(v))\r\n            out[i] = v / norm if norm > 0 else v\r\n        return out\r\n\r\n    def slice(self, vec: EuclideanVec, prefix: Prefix) -> EuclideanVec:\r\n        return vec[..., :prefix]","emb":[-0.0843966081738472,-0.08124422281980515,-0.04021388292312622,-0.023155584931373596,-0.05083516612648964,0.0014833643799647689,-0.09362521022558212,0.017856696620583534,0.04918521270155907,-0.013248929753899574,0.01625858247280121,-0.09514538198709488,0.06046736240386963,0.03276313468813896,0.01196904107928276,0.02331984043121338,0.006264981348067522,0.01844131387770176,-0.055164799094200134,-0.03225012123584747,0.08204639703035355,-0.04177406057715416,-0.020829642191529274,-0.0605802983045578,-0.0031937158200889826,0.009018940851092339,-0.027268311008810997,-0.014357245527207851,-0.041420262306928635,-0.23227250576019287,0.08940614014863968,-0.027002884075045586,0.05731859430670738,-0.032841671258211136,-0.002534344093874097,-0.056416213512420654,-0.056002598255872726,0.009732071310281754,-0.09786608070135117,0.026756402105093002,0.04463328793644905,-0.03049326129257679,-0.05318746343255043,-0.03849398344755173,0.029158439487218857,-0.021941574290394783,-0.05422644317150116,-0.062001146376132965,-0.02147405967116356,-0.02282213792204857,-0.0441228412091732,-0.011457915417850018,0.0018382881535217166,0.024551384150981903,-0.03940513730049133,-0.023136761039495468,0.011139314621686935,0.09388922154903412,0.026823434978723526,0.045296475291252136,-0.01890772022306919,0.049926236271858215,-0.1634732484817505,0.08247774094343185,-0.05804782