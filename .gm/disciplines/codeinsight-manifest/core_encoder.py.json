32)\n            norm = float(np.linalg.norm(v))\n            out[i] = v / norm if norm > 0 else v\n        return out\n\n    def slice(self, vec: EuclideanVec, prefix: Prefix) -> EuclideanVec:\n        return vec[..., :prefix]","emb":[-0.08342206478118896,-0.07818948477506638,-0.04232422634959221,-0.02688130922615528,-0.04955732449889183,-0.00599210849031806,-0.09157869219779968,0.022027449682354927,0.05317377299070358,-0.01144865620881319,0.022632107138633728,-0.10086271911859512,0.060759369283914566,0.035642728209495544,0.015011110343039036,0.01875465176999569,0.0047447942197322845,0.01976729743182659,-0.048799414187669754,-0.030837420374155045,0.07609998434782028,-0.04243389144539833,-0.015183052979409695,-0.058187101036310196,-0.0036129688378423452,0.012462513521313667,-0.028771862387657166,-0.00768239377066493,-0.04335906729102135,-0.23243358731269836,0.08356080949306488,-0.02934190444648266,0.056834086775779724,-0.03551702946424484,0.001442751265130937,-0.05018267408013344,-0.0541936419904232,0.007289932109415531,-0.09122756868600845,0.025980547070503235,0.039900265634059906,-0.03615139424800873,-0.05384714901447296,-0.04018787667155266,0.034144651144742966,-0.025736529380083084,-0.05286988243460655,-0.06352577358484268,-0.021130414679646492,-0.025392092764377594,-0.04663752391934395,-0.012449979782104492,0.004506376571953297,0.02281762845814228,-0.04096373915672302,-0.022682955488562584,0.012873740866780281,0.09226035326719284,0.029678020626306534,0.04671384394168854,-0.02345835044980049,0.048185694962739944,-0.16521629691123962,0.08627957105636597,-0.05312715098261833,0.08100683987140656,-0.055755987763404846,-0.05670325458049774,0.01911032386124134,0.06973873823881149,0.02631673589348793,0.025609340518712997,0.002746261190623045,0.060463469475507736,-0.007746769115328789,0.021891167387366295,0.018626220524311066,-0.04018595069646835,0.013658850453794003,0.050610292702913284,-0.010806925594806671,-0.07866925746202469,-0.0018508874345570803,0.074682950973510